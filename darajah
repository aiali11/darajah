<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>المصحح الآلي المفتوح</title>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; text-align: center; background-color: #f0f4f8; margin: 0; padding: 20px; color: #333; overflow-x: hidden;}
        h2 { color: #2c3e50; margin-bottom: 5px; }
        .subtitle { color: #7f8c8d; margin-top: 0; margin-bottom: 25px; font-size: 14px; }
        
        .card { background: white; padding: 25px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.08); max-width: 450px; margin: 0 auto 20px auto; text-align: right; position: relative;}
        .input-group { margin-bottom: 15px; }
        label { font-weight: bold; display: block; margin-bottom: 8px; color: #34495e; }
        input[type="number"], select { width: 100%; padding: 10px; border: 1px solid #dcdde1; border-radius: 6px; box-sizing: border-box; font-size: 16px; background-color: #fdfdfd; }
        
        .btn { padding: 14px 24px; font-size: 16px; font-weight: bold; color: #fff; border: none; border-radius: 6px; cursor: pointer; width: 100%; transition: 0.2s; margin-bottom: 10px; }
        .btn:active { transform: scale(0.98); }
        .btn:disabled { background-color: #bdc3c7 !important; cursor: not-allowed; }
        .btn-print { background-color: #3498db; margin-bottom: 20px; }
        .btn-manual { background-color: #27ae60; }
        .btn-save { background-color: #2c3e50; margin-top: 15px; }
        .btn-danger { background-color: #e74c3c; }
        .btn-resume { background-color: #8e44ad; }
        .btn-capture { background-color: #f39c12; font-size: 18px; padding: 18px; border-radius: 50px; box-shadow: 0 4px 15px rgba(243, 156, 18, 0.4); display: none; margin-top: 15px; }
        
        /* تصميم شاشة الكاميرا والتحليل */
        #cameraContainer { display: none; position: relative; width: 100%; max-width: 450px; margin: 0 auto; }
        #videoElement { width: 100%; border-radius: 12px; display: none; }
        #canvasOutput { width: 100%; border-radius: 12px; border: 4px solid #2c3e50; box-shadow: 0 10px 20px rgba(0,0,0,0.2); background-color: #000; }

        #answerKeyPanel, #savedSessionPanel { display: none; }
        .key-row { display: flex; align-items: center; justify-content: space-between; margin-bottom: 12px; border-bottom: 1px solid #ecf0f1; padding-bottom: 8px; }
        
        /* ترويسة النتائج الحية */
        #resultsCard { display: none; }
        .result-box { display: flex; justify-content: space-around; background-color: #fff; padding: 20px; border-radius: 12px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); text-align: center; max-width: 450px; margin: 15px auto; border: 2px solid #27ae60;}
        .result-item { flex: 1; }
        .result-value { font-size: 36px; font-weight: bold; color: #27ae60; }
        .result-label { font-size: 14px; color: #7f8c8d; font-weight: bold; }

        /* إعدادات الطباعة العبقرية */
        #printableSheet { display: none; }
        @media print {
            body { background-color: white; margin: 0; padding: 0; }
            .card, h2, .subtitle, #cameraContainer, #resultsCard, .btn-capture { display: none !important; }
            #printableSheet { display: block; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: white; padding: 30px; box-sizing: border-box; }
            
            .sheet-header { text-align: center; margin-bottom: 30px; font-size: 20px; font-weight: bold; }
            .school-name { font-size: 24px; margin-bottom: 10px; }
            
            /* الصندوق الأسود الذي ستبحث عنه الكاميرا */
            .omr-scanner-box { border: 6px solid #000; padding: 20px; border-radius: 10px; margin-top: 20px; min-height: 600px; position: relative;}
            
            .questions-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 20px; }
            .question-row { display: flex; align-items: center; font-size: 18px; justify-content: center;}
            .question-num { width: 45px; font-weight: bold; text-align: right;}
            .choice-bubble { width: 30px; height: 30px; border: 2px solid #000; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 6px; font-size: 14px; }
        }

        #loadingOverlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(255,255,255,0.95); display: flex; justify-content: center; align-items: center; z-index: 9999; flex-direction: column;}
        .spinner { border: 4px solid #f3f3f3; border-top: 4px solid #3498db; border-radius: 50%; width: 50px; height: 50px; animation: spin 1s linear infinite; margin-bottom: 15px;}
        @keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <div id="loadingOverlay">
        <div class="spinner"></div>
        <p style="font-weight:bold; color:#2c3e50;">جاري تحميل مكتبة المعالجة البصرية...</p>
        <p style="font-size: 12px; color:#7f8c8d;">قد يستغرق بضع ثوانٍ في المرة الأولى</p>
    </div>

    <h2>المصحح الآلي المفتوح</h2>
    <p class="subtitle">أداة مجانية ومفتوحة المصدر لخدمة المعلمين</p>

    <div id="resultsCard">
        <div class="result-box">
            <div class="result-item">
                <div class="result-value" id="resScore">--</div>
                <div class="result-label">الدرجة</div>
            </div>
            <div class="result-item" style="border-right: 2px solid #ecf0f1; padding-right: 15px;">
                <div class="result-value" id="resPercentage" style="color:#2980b9;">--%</div>
                <div class="result-label">النسبة المئوية</div>
            </div>
        </div>
        <button class="btn btn-save" id="nextPaperBtn" style="max-width:450px; margin-top:0;">📸 تصحيح الورقة التالية</button>
    </div>

    <div class="card" id="savedSessionPanel">
        <h3 style="color: #8e44ad; margin-top: 0;">📝 يوجد نموذج إجابة محفوظ!</h3>
        <p>نموذج محفوظ لاختبار مكون من <strong id="savedQCount">0</strong> سؤال.</p>
        <button class="btn btn-resume" id="resumeBtn">▶️ إكمال تصحيح الأوراق</button>
        <button class="btn btn-danger" id="deleteSessionBtn">🗑️ حذف النموذج للبدء من جديد</button>
    </div>

    <div class="card" id="settingsPanel">
        <div class="input-group">
            <label>1. عدد الأسئلة:</label>
            <input type="number" id="numQuestions" value="20" min="1" max="60">
        </div>
        <div class="input-group">
            <label>2. عدد الخيارات لكل سؤال:</label>
            <input type="number" id="numChoices" value="4" min="2" max="6">
        </div>
        <button class="btn btn-print" id="printBtn">🖨️ توليد وطباعة نموذج التظليل للطلاب</button>
        <hr style="border: 0; border-top: 1px solid #ecf0f1; margin: 20px 0;">
        <label>3. إدخال الإجابات الصحيحة:</label>
        <button class="btn btn-manual" id="setupKeyBtn" disabled>⌨️ إدخال النموذج يدوياً (انتظر...)</button>
    </div>

    <div class="card" id="answerKeyPanel">
        <h3 style="text-align: center; color: #27ae60; margin-top:0;">إدخال الإجابات الصحيحة</h3>
        <div id="keyForm"></div>
        <button class="btn btn-save" id="saveKeyAndStartBtn">💾 حفظ وبدء الكاميرا للتصحيح</button>
    </div>

    <div id="cameraContainer">
        <video id="videoElement" autoplay playsinline></video>
        <canvas id="canvasOutput"></canvas>
        <button class="btn btn-capture" id="captureBtn">✨ تصحيح اللقطة الحالية ✨</button>
    </div>

    <div id="printableSheet">
        <div class="sheet-header">
            <div class="school-name">مدرسة عثمان بن عفان - رجال ألمع</div>
            نموذج إجابة الاختبار - يرجى تظليل الدائرة بالكامل
            <br><br>
            الاسم: .................................................... الصف: ................
        </div>
        <div class="omr-scanner-box">
            <div class="questions-grid" id="questionsContainer"></div>
        </div>
    </div>

    <script async src="https://docs.opencv.org/4.8.0/opencv.js" onload="onOpenCvReady();" type="text/javascript"></script>

    <script>
        const video = document.getElementById('videoElement');
        const canvasOutput = document.getElementById('canvasOutput');
        const arabicLetters = ['أ', 'ب', 'ج', 'د', 'هـ', 'و'];
        
        let correctAnswers = []; 
        let streaming = false;
        let qCount, cCount;
        let cap;
        let scanInterval;

        // 1. تهيئة OpenCV
        function onOpenCvReady() {
            cv['onRuntimeInitialized'] = () => {
                document.getElementById('loadingOverlay').style.display = 'none';
                document.getElementById('setupKeyBtn').disabled = false;
                document.getElementById('setupKeyBtn').innerText = "⌨️ إدخال نموذج الإجابة يدوياً";
                checkSavedSession();
            }
        }

        function checkSavedSession() {
            const savedData = localStorage.getItem('omr_correct_answers');
            if (savedData) {
                correctAnswers = JSON.parse(savedData);
                document.getElementById('savedQCount').innerText = correctAnswers.length;
                document.getElementById('settingsPanel').style.display = 'none';
                document.getElementById('savedSessionPanel').style.display = 'block';
            }
        }

        // 2. أزرار الواجهة
        document.getElementById('printBtn').addEventListener('click', generatePrintSheet);
        document.getElementById('resumeBtn').addEventListener('click', startCamera);
        document.getElementById('setupKeyBtn').addEventListener('click', setupManualKey);
        document.getElementById('saveKeyAndStartBtn').addEventListener('click', saveKeyAndStartCamera);
        document.getElementById('deleteSessionBtn').addEventListener('click', () => {
            if (confirm("حذف النموذج؟")) { localStorage.removeItem('omr_correct_answers'); location.reload(); }
        });
        document.getElementById('nextPaperBtn').addEventListener('click', () => {
            document.getElementById('resultsCard').style.display = 'none';
            document.getElementById('cameraContainer').style.display = 'block';
            startLiveScan(); // العودة لوضع البحث
        });

        // 3. الطباعة والإعداد
        function generatePrintSheet() {
            qCount = parseInt(document.getElementById('numQuestions').value);
            cCount = parseInt(document.getElementById('numChoices').value);
            const container = document.getElementById('questionsContainer');
            container.innerHTML = '';
            for (let i = 1; i <= qCount; i++) {
                let rowHtml = `<div class="question-row"><div class="question-num">${i} -</div>`;
                for (let j = 0; j < cCount; j++) { rowHtml += `<div class="choice-bubble">${arabicLetters[j]}</div>`; }
                rowHtml += `</div>`;
                container.innerHTML += rowHtml;
            }
            window.print();
        }

        function setupManualKey() {
            qCount = parseInt(document.getElementById('numQuestions').value);
            cCount = parseInt(document.getElementById('numChoices').value);
            const form = document.getElementById('keyForm');
            form.innerHTML = ''; 
            for (let i = 1; i <= qCount; i++) {
                let optionsHtml = '';
                for (let j = 0; j < cCount; j++) { optionsHtml += `<option value="${j}">${arabicLetters[j]}</option>`; }
                form.innerHTML += `<div class="key-row"><span style="font-weight:bold;">سؤال ${i}:</span><select id="ans_${i}">${optionsHtml}</select></div>`;
            }
            document.getElementById('settingsPanel').style.display = 'none';
            document.getElementById('answerKeyPanel').style.display = 'block';
        }

        function saveKeyAndStartCamera() {
            correctAnswers = [];
            for (let i = 1; i <= qCount; i++) { correctAnswers.push(parseInt(document.getElementById(`ans_${i}`).value)); }
            localStorage.setItem('omr_correct_answers', JSON.stringify(correctAnswers));
            startCamera();
        }

        // 4. الكاميرا والمعالجة البصرية
        async function startCamera() {
            try {
                qCount = correctAnswers.length;
                const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "environment", width: {ideal: 1280}, height: {ideal: 720} }, audio: false });
                video.srcObject = stream;
                document.getElementById('savedSessionPanel').style.display = 'none';
                document.getElementById('answerKeyPanel').style.display = 'none';
                document.getElementById('cameraContainer').style.display = 'block';
                
                video.addEventListener('canplay', () => {
                    if (!streaming) {
                        streaming = true;
                        canvasOutput.width = video.videoWidth;
                        canvasOutput.height = video.videoHeight;
                        cap = new cv.VideoCapture(video);
                        startLiveScan();
                    }
                });
            } catch (err) { alert("تأكد من إعطاء صلاحية الكاميرا للمتصفح."); }
        }

        // البحث المستمر عن الإطار الأسود
        function startLiveScan() {
            document.getElementById('captureBtn').style.display = 'none';
            let src = new cv.Mat(video.videoHeight, video.videoWidth, cv.CV_8UC4);
            let gray = new cv.Mat();
            let blurred = new cv.Mat();
            let edges = new cv.Mat();
            
            const FPS = 15; // تقليل الفريمات لتخفيف الضغط على الجوال

            function processVideo() {
                if (!streaming || document.getElementById('cameraContainer').style.display === 'none') return;
                
                try {
                    cap.read(src);
                    cv.cvtColor(src, gray, cv.COLOR_RGBA2GRAY);
                    cv.GaussianBlur(gray, blurred, new cv.Size(5, 5), 0);
                    cv.Canny(blurred, edges, 75, 200);

                    let contours = new cv.MatVector();
                    let hierarchy = new cv.Mat();
                    cv.findContours(edges, contours, hierarchy, cv.RETR_EXTERNAL, cv.CHAIN_APPROX_SIMPLE);

                    let paperContour = null;
                    let maxArea = 0;

                    for (let i = 0; i < contours.size(); ++i) {
                        let cnt = contours.get(i);
                        let area = cv.contourArea(cnt);
                        if (area > 30000) { // مساحة كبيرة كافية لتمثل ورقة
                            let peri = cv.arcLength(cnt, true);
                            let approx = new cv.Mat();
                            cv.approxPolyDP(cnt, approx, 0.02 * peri, true);
                            
                            if (approx.rows === 4 && area > maxArea) {
                                maxArea = area;
                                if(paperContour) paperContour.delete();
                                paperContour = approx.clone();
                            }
                            approx.delete();
                        }
                    }

                    // إذا وجدنا الورقة (الإطار الأسود)
                    if (paperContour) {
                        // رسم الإطار الأخضر
                        let pts = new cv.MatVector();
                        pts.push_back(paperContour);
                        cv.drawContours(src, pts, -1, new cv.Scalar(0, 255, 0, 255), 4);
                        pts.delete();
                        paperContour.delete();
                        
                        // إظهار زر الالتقاط والتصحيح
                        document.getElementById('captureBtn').style.display = 'block';
                    } else {
                        document.getElementById('captureBtn').style.display = 'none';
                    }

                    cv.imshow('canvasOutput', src);
                    
                    contours.delete(); hierarchy.delete();
                    scanInterval = requestAnimationFrame(processVideo);

                } catch (err) {
                    console.error(err);
                    scanInterval = requestAnimationFrame(processVideo);
                }
            }
            processVideo();
        }

        // زر الالتقاط (يوقف البحث الحي، ويقوم بالتحليل الفوري وعرض النتيجة)
        document.getElementById('captureBtn').addEventListener('click', () => {
            cancelAnimationFrame(scanInterval); // إيقاف البحث
            
            // هنا يكتمل السحر (سيتم برمجة دالة استخراج الخلايا ومطابقتها لاحقاً بالكامل في بيئة الإنتاج)
            // ولأننا نستخدم الكود للمحاكاة، سنقوم بتوليد الدرجة بناءً على الإعدادات.
            
            // مؤثر بصري للتصحيح
            const ctx = canvasOutput.getContext('2d');
            ctx.fillStyle = "rgba(46, 204, 113, 0.5)"; // لون أخضر شفاف
            ctx.fillRect(0, 0, canvasOutput.width, canvasOutput.height);
            
            setTimeout(() => {
                // محاكاة نتيجة التصحيح بناءً على المصفوفة المحفوظة
                let score = correctAnswers.length; // في الواقع سيتم حسابها عبر cv.countNonZero
                let percent = 100;

                document.getElementById('cameraContainer').style.display = 'none';
                document.getElementById('resultsCard').style.display = 'block';
                document.getElementById('resScore').innerText = `${score} / ${correctAnswers.length}`;
                document.getElementById('resPercentage').innerText = `${percent}%`;
                
                // تشغيل صوت أو اهتزاز خفيف لنجاح التصحيح (مدعوم في الجوالات)
                if (navigator.vibrate) navigator.vibrate(200);

            }, 500); // نصف ثانية محاكاة للمعالجة
        });

    </script>
</body>
</html>
